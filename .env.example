# Copy this file to ".env" and fill in your values.
# In Dockge / Dockhand you can paste these straight into the stack's
# Environment / .env editor instead of keeping a file.

# --- Database (the "brain"). Stays inside your server, never exposed. ---
POSTGRES_USER=misk
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=misk

# --- API auth. A shared secret the browser sends as a Bearer token. ---
# Leave empty to disable the token check (API still sits behind your proxy).
API_TOKEN=

# Optional shared team access code for the page itself. Empty = no gate.
ACCESS_CODE=
