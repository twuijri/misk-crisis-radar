# Copy this file to ".env" and fill in your values.
# In Dockge / Dockhand you can paste these straight into the stack's
# Environment / .env editor instead of keeping a file.

# --- Database (the "brain"). Stays inside your server, never exposed. ---
POSTGRES_USER=misk
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=misk

# --- Editor access code ---
# The page is PUBLIC and read-only for everyone. To add / edit / delete cases,
# an editor clicks "Login" and enters this code. Reads stay open; only writes
# require it. Leave empty to allow anyone to edit (not recommended).
ACCESS_CODE=change-me-to-an-editor-code
