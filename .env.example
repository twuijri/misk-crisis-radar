# Copy this file to ".env" and fill in your values.
# In Dockge / Dockhand you can paste these straight into the stack's
# Environment / .env editor instead of keeping a file.

# From Supabase: Project Settings -> API -> Project URL (no trailing slash)
SUPABASE_URL=https://your-project-ref.supabase.co

# From Supabase: Project Settings -> API -> "anon public" key
# (this key is designed to be public in the browser)
SUPABASE_ANON_KEY=your-long-anon-public-key

# Optional shared team access code. Leave empty for no gate.
ACCESS_CODE=
